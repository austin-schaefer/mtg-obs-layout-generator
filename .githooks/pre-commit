#!/usr/bin/env bash
# Enforces: if you change code in a tracked directory, you also stage that
# directory's README.md in the same commit. Enable once per clone:
#   git config core.hooksPath .githooks
#
# This hook is *staging-aware*, not *content-aware*: it only confirms the README
# is in the same staged changeset as the touched code. A drive-by README touch
# passes the gate even if the README's claims are stale. The accuracy contract is
# upheld by periodic review, not by this hook — when editing a sub-README during a
# code change, re-read the surrounding section and audit it against the new code.
#
# The legacy Python (download_images.py, booster_builder.py, cleanup.py, scry) is
# intentionally NOT tracked here — it's frozen reference and shouldn't change.

set -euo pipefail

# dir:readme-path  (readme path is relative to repo root)
TRACKED=(
  "scripts:scripts/README.md"
  "src:src/README.md"
)

CODE_EXT_RE='\.(sh|ts|tsx|astro|mjs|js|jsx|cjs|cts|mts|css)$'

staged=$(git diff --cached --name-only --diff-filter=ACMR)
[[ -z "$staged" ]] && exit 0

violations=()

for entry in "${TRACKED[@]}"; do
  dir="${entry%%:*}"
  readme="${entry#*:}"

  # any code file staged under this dir?
  code_changed=$(printf '%s\n' "$staged" \
    | grep -E "^${dir}/" \
    | grep -E "$CODE_EXT_RE" \
    || true)

  if [[ -n "$code_changed" ]]; then
    if ! printf '%s\n' "$staged" | grep -qx "$readme"; then
      violations+=("$dir → update $readme")
    fi
  fi
done

if (( ${#violations[@]} > 0 )); then
  echo
  echo "✗ pre-commit: README updates required"
  echo
  echo "  You changed code in tracked directories but didn't stage the matching README."
  echo "  Update the README to reflect your changes, then re-stage and commit."
  echo
  for v in "${violations[@]}"; do
    echo "    - $v"
  done
  echo
  echo "  Bypass (only if you truly mean it): git commit --no-verify"
  echo
  exit 1
fi

exit 0
