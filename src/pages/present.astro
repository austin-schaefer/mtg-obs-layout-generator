---
import BaseLayout from "../layouts/BaseLayout.astro";
import PresenterApp from "../components/PresenterApp.tsx";
---

<BaseLayout title="Presenter — obs-layouts">
  <div style="position: fixed; inset: 0;">
    <PresenterApp client:load />
  </div>

  <!-- Subtle escape hatch; sits above the stage, out of the way for screen-share. -->
  <a
    href="/"
    style="position: fixed; top: 10px; left: 12px; z-index: 10; font-size: 13px;
           color: rgba(255,255,255,0.55); text-decoration: none;
           text-shadow: 0 1px 4px rgba(0,0,0,0.8);"
  >
    ← back
  </a>
</BaseLayout>
